{
  "manifest_version": 3,
  "name": "Apex OS",
  "description": "High-performance terminal dashboard with dual-thermal monitoring by Apex Labs.",
  "version": "1.5",
  "permissions": [
    "storage",
    "geolocation"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://api.bigdatacloud.net/*"
  ],
  "chrome_url_overrides": {
    "newtab": "homepage.html"
  }
}
